{
  "__comment__": "NAS3R 训练任务 · Arnold/Merlin 环境变量配置 · 8×H100 80GB 单实例 · v1.0",
  "__instructions__": [
    "把本文件 envs 字段下的所有 KEY=VALUE 对贴到 Arnold 任务提交页面 -> 环境变量 (JSON) 字段。",
    "以 __ 开头的字段是注释，提交时请删除或被平台忽略。",
    "WANDB_API_KEY 替换成你的真实 key；不写会降级为 offline，不影响训练。"
  ],
  "envs": {

    "__CATEGORY_1__": "========== NCCL · 分布式通信（8卡 H100 单机）==========",
    "NCCL_DEBUG": "WARN",
    "NCCL_ASYNC_ERROR_HANDLING": "1",
    "NCCL_IB_DISABLE": "0",
    "NCCL_P2P_DISABLE": "0",
    "NCCL_IB_GID_INDEX": "3",

    "__CATEGORY_2__": "========== Arnold 平台 GPU 亲和性 ==========",
    "ARNOLD_GPU_NIC_AFFINITY": "0",
    "ARNOLD_IPV6": "1",

    "__CATEGORY_3__": "========== byted-torch / BYTECCL（字节自家 PyTorch 加速）==========",
    "BYTED_TORCH_BYTECCL": "O0",
    "BYTED_TORCH_FX": "O0",

    "__CATEGORY_4__": "========== CUDA 运行时 · 内存碎片优化 ==========",
    "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True",
    "CUDA_DEVICE_MAX_CONNECTIONS": "1",

    "__CATEGORY_5__": "========== Python 应用层 · HuggingFace / Hydra / 输出缓冲 ==========",
    "HF_HUB_ENABLE_HF_TRANSFER": "1",
    "HYDRA_FULL_ERROR": "1",
    "PYTHONUNBUFFERED": "1",
    "TOKENIZERS_PARALLELISM": "false",

    "__CATEGORY_6__": "========== H100 CUDA 编译（pytorch3d / diff_gauss_camera）==========",
    "TORCH_CUDA_ARCH_LIST": "9.0",
    "FORCE_CUDA": "1",
    "MAX_JOBS": "8",

    "__CATEGORY_7__": "========== Weights & Biases（训练可视化，可选）==========",
    "WANDB_API_KEY": "TODO_FILL_YOUR_WANDB_KEY_OR_REMOVE_THIS_LINE",
    "WANDB_MODE": "online",
    "WANDB_PROJECT": "nas3r",

    "__CATEGORY_8__": "========== 应用侧业务参数（train.sh 会读取）==========",
    "PARENT_DIR": "/opt/tiger/mmfinetune",
    "PER_GPU_BATCH": "5",
    "MAX_STEPS": "400001",
    "VAL_CHECK_INTERVAL": "10000",
    "CKPT_EVERY_N_STEPS": "5000",
    "SAVE_TOP_K": "3",
    "NUM_WORKERS": "8",
    "RESUME": "auto"

  }
}
